# Security
JWT_SECRET_KEY=change-me-to-a-random-string-in-production

# Default admin credentials (used on first seed)
DEFAULT_ADMIN_EMAIL=admin@quickpulse.local
DEFAULT_ADMIN_PASSWORD=changeme

# Database
DATABASE_URL=postgresql+asyncpg://quickpulse:quickpulse@localhost:5432/quickpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Application
DEBUG=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
