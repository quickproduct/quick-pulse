# ============================================================================
# QuickPulse - Unified Environment Configuration
# ============================================================================
# Copy this file to .env and update values accordingly.
# Default values are optimized for local development.

# ── General Configuration ──────────────────────────────────────────────────
ENVIRONMENT=development
CONTAINER_PREFIX=qp
DEBUG=true
LOG_LEVEL=DEBUG

# ── Security ───────────────────────────────────────────────────────────────
# Generate a secure key for production: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=AIzaSyDoQJy6Etha-Nltrc6-RfOh1iXh9P6WGU4
JWT_ALGORITHM=HS256

# ── Initial Admin Account ──────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@quickpulse.local
DEFAULT_ADMIN_PASSWORD=admin

# ── Network Configuration ──────────────────────────────────────────────────
EXTERNAL_FRONTEND_PORT=80
EXTERNAL_BACKEND_PORT=8000
EXTERNAL_DB_PORT=5432
EXTERNAL_REDIS_PORT=6379
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ── Database Configuration ──────────────────────────────────────────────────
DB_USER=quickpulse
DB_PASSWORD=quickpulse
DB_NAME=quickpulse
# DATABASE_URL is constructed automatically in docker-compose.yml, 
# but can be overridden here if needed:
# DATABASE_URL=postgresql+asyncpg://quickpulse:quickpulse@db:5432/quickpulse

# ── Redis Configuration ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_MAX_MEMORY=64mb

# ── Docker Integration ──────────────────────────────────────────────────────
DOCKER_SOCKET_PATH=/var/run/docker.sock

# ── SaaS & Registration ─────────────────────────────────────────────────────
ALLOW_REGISTRATION=true
DEFAULT_PLAN=free
TRIAL_DAYS=14

# ── Stripe Integration (Optional) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resource Limits (Optional) ──────────────────────────────────────────────
BACKEND_CPUS=1
BACKEND_MEMORY=512m
DB_CPUS=1
DB_MEMORY=512m
REDIS_CPUS=0.5
REDIS_MEMORY=128m
FRONTEND_CPUS=0.5
FRONTEND_MEMORY=256m

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_DIR=/app/logs
