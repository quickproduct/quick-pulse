# QuickPulse environment configuration
# Copy this file to .env and update values before running Docker Compose.

# General configuration
ENVIRONMENT=development
CONTAINER_PREFIX=qp
DEBUG=true
LOG_LEVEL=DEBUG

# Security
# Generate a secure key for production: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# Initial admin account
DEFAULT_ADMIN_EMAIL=admin@quickpulse.local
DEFAULT_ADMIN_PASSWORD=admin

# Network configuration
EXTERNAL_FRONTEND_PORT=80
# Leave empty for same-origin requests only.
CORS_ALLOW_ORIGIN=

# Docker integration
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Kubernetes integration
# docker-compose.yml mounts ~/.kube/config for local Kubernetes access.
K8S_SERVER_OVERRIDE=

# Registration
ALLOW_REGISTRATION=true

# Metrics retention
METRICS_RETENTION_DAYS=30
METRICS_COLLECTION_INTERVAL_SECONDS=10
METRICS_DOWNSAMPLE_THRESHOLD_HOURS=24

# Logging
LOG_DIR=/app/logs
