	<!-- Animation & Simulator Client Script -->
	<script>
		import { animate, stagger } from "motion";

		document.addEventListener("astro:page-load", () => {
			// Hero Entrance
			animate(".hero-content", { opacity: [0, 1], y: [20, 0] }, { duration: 0.8, easing: "ease-out" });
			// Stats Entrance
			animate(".stats-section", { opacity: [0, 1], y: [15, 0] }, { delay: 0.3, duration: 0.8, easing: "ease-out" });
			// Staggered features Entrance
			animate(".feature-item", { opacity: [0, 1], y: [20, 0] }, { delay: stagger(0.1, { start: 0.5 }), duration: 0.6, easing: "ease-out" });

			// ==========================================
			// Live Interactive Sandbox Simulator Logic
			// ==========================================
			const simCpuCircle = document.getElementById("sim-cpu-circle");
			const simCpuTxt = document.getElementById("sim-cpu-txt");
			const simMemCircle = document.getElementById("sim-mem-circle");
			const simMemTxt = document.getElementById("sim-mem-txt");
			const simNetCircle = document.getElementById("sim-net-circle");
			const simNetTxt = document.getElementById("sim-net-txt");
			const logsContainer = document.getElementById("sim-logs-container");

			const btnSpike = document.getElementById("btn-spike");
			const btnRestart = document.getElementById("btn-restart");
			const btnToggleWorker = document.getElementById("btn-toggle-worker");

			const containerDbStatus = document.getElementById("container-db-status");
			const containerWorkerStatus = document.getElementById("container-worker-status");

			let baselineCpu = 8.5;
			let baselineMem = 37.2;
			let containerCount = 3;
			let isWorkerRunning = true;
			let isCpuSpiking = false;

			// Shared logs data
			const baseLogs = [
				{ text: "Initialization completed. Running SQLite WAL...", level: "info", timestamp: "02:05:12" },
				{ text: "Background telemetry goroutine started successfully.", level: "info", timestamp: "02:05:12" },
				{ text: "WebSocket connected successfully to /ws/metrics.", level: "info", timestamp: "02:05:13" },
				{ text: "Incoming client connection authorized on session context 7.", level: "info", timestamp: "02:05:15" },
				{ text: "Database backup completed: 25.1KB saved to disk.", level: "info", timestamp: "02:05:20" },
				{ text: "Memory consumption at 82.4% for service 'quickpulse-backend'.", level: "warn", timestamp: "02:05:35" },
				{ text: "Alert condition hit: CPU load average 1m exceeds threshold.", level: "warn", timestamp: "02:05:40" },
				{ text: "Pod scaled successfully: web-deployment replica count at 4.", level: "info", timestamp: "02:06:01" },
				{ text: "Re-establishing websocket connection stream to Kubernetes engine.", level: "info", timestamp: "02:06:10" },
				{ text: "Connection lost to local docker socket: connection refused.", level: "error", timestamp: "02:06:12" },
				{ text: "Health check failed for sqlite-database: connection pool saturated.", level: "error", timestamp: "02:06:15" },
				{ text: "Automatic container restart sequence started for sqlite-database.", level: "warn", timestamp: "02:06:16" }
			];

			// Append log line helper
			function addLog(text: string, level = "info") {
				const timestamp = new Date().toLocaleTimeString();
				baseLogs.push({ text, level, timestamp });
				
				// Standard dashboard logs view append
				if (logsContainer) {
					const div = document.createElement("div");
					if (level === "critical" || level === "error") {
						div.className = "text-red-500 font-bold";
						div.textContent = `[ERROR] ${timestamp} - ${text}`;
					} else if (level === "warning" || level === "warn") {
						div.className = "text-amber-400";
						div.textContent = `[WARN] ${timestamp} - ${text}`;
					} else {
						div.className = "text-slate-300";
						div.textContent = `[INFO] ${timestamp} - ${text}`;
					}
					logsContainer.appendChild(div);
					logsContainer.scrollTop = logsContainer.scrollHeight;
					if (logsContainer.children.length > 25) {
						logsContainer.removeChild(logsContainer.firstChild);
					}
				}

				// Refresh full logs view
				renderFullLogs();
			}

			// Update Gauge UI
			function updateGauge(circle: HTMLElement | null, text: HTMLElement | null, percent: number, circumference = 176) {
				if (!circle || !text) return;
				const offset = circumference - (percent / 100) * circumference;
				circle.setAttribute("stroke-dashoffset", String(offset));
				text.textContent = `${percent.toFixed(0)}%`;
			}

			// Telemetry fluctuation loop
			setInterval(() => {
				if (isCpuSpiking) return;

				// Random subtle load fluctuations
				const cpuVal = baselineCpu + (Math.random() * 4 - 2);
				const memVal = baselineMem + (Math.random() * 0.4 - 0.2);

				updateGauge(simCpuCircle, simCpuTxt, Math.max(1, cpuVal));
				updateGauge(simMemCircle, simMemTxt, memVal);

				// Fluctuate CPU usages in Containers tab
				const bkCpu = document.getElementById("sim-card-backend-cpu");
				const bkBar = document.getElementById("sim-card-backend-bar");
				const dbCpu = document.getElementById("sim-card-db-cpu");
				const dbBar = document.getElementById("sim-card-db-bar");
				const wkCpu = document.getElementById("sim-card-worker-cpu");
				const wkBar = document.getElementById("sim-card-worker-bar");

				if (bkCpu && bkBar) {
					const val = 0.4 + (Math.random() * 0.2 - 0.1);
					bkCpu.textContent = `${val.toFixed(2)}%`;
					bkBar.style.width = `${val * 25}%`;
				}
				if (dbCpu && dbBar) {
					const val = 0.1 + (Math.random() * 0.06 - 0.03);
					dbCpu.textContent = `${val.toFixed(2)}%`;
					dbBar.style.width = `${val * 30}%`;
				}
				if (wkCpu && wkBar && isWorkerRunning) {
					const val = 0.8 + (Math.random() * 0.4 - 0.2);
					wkCpu.textContent = `${val.toFixed(2)}%`;
					wkBar.style.width = `${val * 20}%`;
				}
			}, 2000);

			// Action: CPU load spike simulation
			btnSpike?.addEventListener("click", () => {
				if (isCpuSpiking) return;
				isCpuSpiking = true;
				addLog("Synthesized cpu load spike initiated...", "warn");

				// Animate up
				let currentCpu = baselineCpu;
				const interval = setInterval(() => {
					currentCpu += 15;
					if (currentCpu >= 94.6) {
						currentCpu = 94.6;
						clearInterval(interval);
						
						// UI Alert styles
						if (simCpuCircle) simCpuCircle.setAttribute("stroke", "#ef4444");
						if (simCpuTxt) simCpuTxt.className = "absolute inset-0 flex items-center justify-center font-mono text-sm text-red-400 font-bold animate-pulse";
						
						addLog("Host warning: CPU utilization exceeded 90%!", "error");
						addLog("Alert rule 'High Host CPU' flagged successfully", "warn");

						// Cool down after 4.5 seconds
						setTimeout(() => {
							addLog("Spike load simulator cooling down...", "info");
							const coolInterval = setInterval(() => {
								currentCpu -= 12;
								if (currentCpu <= baselineCpu) {
									currentCpu = baselineCpu;
									clearInterval(coolInterval);
									isCpuSpiking = false;
									
									// Revert styles
									if (simCpuCircle) simCpuCircle.setAttribute("stroke", "#818cf8");
									if (simCpuTxt) simCpuTxt.className = "absolute inset-0 flex items-center justify-center font-mono text-sm text-white font-bold";
									addLog("CPU metrics recovered to normal levels.", "info");
								}
								updateGauge(simCpuCircle, simCpuTxt, currentCpu);
							}, 200);
						}, 4500);
					}
					updateGauge(simCpuCircle, simCpuTxt, currentCpu);
				}, 100);
			});

			// Action: Restart container simulation (helper)
			function handleDbRestart() {
				const statusElements = [containerDbStatus, document.getElementById("sim-card-db-status")];
				addLog("Instructing docker engine to restart 'sqlite-database' container...", "info");
				
				statusElements.forEach(el => {
					if (!el) return;
					el.className = "px-2 py-0.5 rounded text-[10px] bg-amber-500/10 text-amber-400 border border-amber-500/20 animate-pulse";
					el.textContent = "Restarting";
				});
				addLog("[sqlite-database] Shutting connection handler threads down.", "info");

				setTimeout(() => {
					statusElements.forEach(el => {
						if (!el) return;
						el.className = "px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20";
						el.textContent = "Running";
					});
					addLog("[sqlite-database] Container spawned. Entrypoint running.", "info");
					addLog("[sqlite-database] SQLite DB handle re-opened. WAL mode verified.", "info");
					addLog("Database health check returned: 200 OK.", "info");
				}, 2500);
			}

			btnRestart?.addEventListener("click", handleDbRestart);
			document.getElementById("btn-card-restart-db")?.addEventListener("click", handleDbRestart);

			// Restart handlers for other containers in card view
			document.getElementById("btn-card-restart-backend")?.addEventListener("click", () => {
				addLog("Instructing docker engine to restart 'quickpulse-backend' container...", "info");
				addLog("[quickpulse-backend] Gracefully terminated router daemon.", "info");
				setTimeout(() => {
					addLog("[quickpulse-backend] Gunicorn core listener active. Port 8000 bound.", "info");
				}, 1500);
			});

			document.getElementById("btn-card-restart-redis")?.addEventListener("click", () => {
				addLog("Instructing docker engine to restart 'redis-cache' container...", "info");
				addLog("[redis-cache] Saving DB database snapshots to disk...", "info");
				setTimeout(() => {
					addLog("[redis-cache] Redis TCP listener port 6379 initialized.", "info");
				}, 1000);
			});

			// Action: Toggle worker container state
			function handleWorkerToggle() {
				const statusElements = [containerWorkerStatus, document.getElementById("sim-card-worker-status")];
				const toggleBtns = [btnToggleWorker, document.getElementById("btn-card-toggle-worker")];
				const wkCpu = document.getElementById("sim-card-worker-cpu");
				const wkBar = document.getElementById("sim-card-worker-bar");
				
				isWorkerRunning = !isWorkerRunning;

				if (isWorkerRunning) {
					statusElements.forEach(el => {
						if (!el) return;
						el.className = "px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20";
						el.textContent = "Running";
					});
					toggleBtns.forEach(btn => {
						if (!btn) return;
						if (btn.id === 'btn-toggle-worker') {
							btn.className = "qp-btn qp-btn-ghost col-span-2 px-2 py-2 text-[10px] hover:border-amber-500/50 hover:text-amber-400";
							btn.textContent = "🛑 Toggle Batch Worker";
						} else {
							btn.className = "qp-btn qp-btn-ghost px-2 py-1 flex-1 text-red-400 hover:bg-red-500/10 hover:border-red-500/20";
							btn.textContent = "Stop";
						}
					});
					containerCount = 3;
					if (simNetCircle && simNetTxt) {
						simNetCircle.setAttribute("stroke-dashoffset", "44");
						simNetTxt.textContent = "3/4";
					}
					const countEl = document.getElementById("sim-containers-count");
					if (countEl) countEl.textContent = "Total: 3 Active";

					addLog("Starting container 'batch-worker'...", "info");
					addLog("[batch-worker] Started batch-job queues daemon.", "info");
				} else {
					statusElements.forEach(el => {
						if (!el) return;
						el.className = "px-2 py-0.5 rounded text-[10px] bg-red-500/10 text-red-400 border border-red-500/20";
						el.textContent = "Stopped";
					});
					toggleBtns.forEach(btn => {
						if (!btn) return;
						if (btn.id === 'btn-toggle-worker') {
							btn.className = "qp-btn qp-btn-ghost col-span-2 px-2 py-2 text-[10px] border-emerald-500/30 text-emerald-400 hover:bg-emerald-500/10";
							btn.textContent = "▶ Start Batch Worker";
						} else {
							btn.className = "qp-btn qp-btn-ghost px-2 py-1 flex-1 text-emerald-400 hover:bg-emerald-500/10 hover:border-emerald-500/20";
							btn.textContent = "Start";
						}
					});
					containerCount = 2;
					if (simNetCircle && simNetTxt) {
						simNetCircle.setAttribute("stroke-dashoffset", "88");
						simNetTxt.textContent = "2/4";
					}
					const countEl = document.getElementById("sim-containers-count");
					if (countEl) countEl.textContent = "Total: 2 Active";

					if (wkCpu) wkCpu.textContent = "0.00%";
					if (wkBar) wkBar.style.width = "0%";

					addLog("Stopping container 'batch-worker'...", "warn");
					addLog("[batch-worker] Process terminated with signal 15.", "warn");
				}
			}

			btnToggleWorker?.addEventListener("click", handleWorkerToggle);
			document.getElementById("btn-card-toggle-worker")?.addEventListener("click", handleWorkerToggle);
			document.getElementById("btn-card-restart-worker")?.addEventListener("click", () => {
				addLog("Instructing docker engine to restart 'batch-worker' container...", "info");
				addLog("[batch-worker] Restarting process worker threads...", "info");
			});

			// ==========================================
			// Navigation Tab Switching & Animations
			// ==========================================
			const tabButtons = document.querySelectorAll("#sandbox-tabs button");
			const viewPanels = [
				{ id: "dashboard", el: document.getElementById("sim-view-dashboard") },
				{ id: "containers", el: document.getElementById("sim-view-containers") },
				{ id: "kubernetes", el: document.getElementById("sim-view-kubernetes") },
				{ id: "logs", el: document.getElementById("sim-view-logs") }
			];

			tabButtons.forEach(btn => {
				btn.addEventListener("click", () => {
					const targetTab = btn.getAttribute("data-tab");
					if (!targetTab) return;

					// Deactivate other tabs
					tabButtons.forEach(b => {
						b.className = "w-full flex items-center gap-2 p-2 text-slate-400 hover:bg-white/[0.02] hover:text-white rounded transition-all duration-200 cursor-pointer text-left focus:outline-none border border-transparent";
					});

					// Activate this tab
					btn.className = "w-full flex items-center gap-2 p-2 bg-indigo-500/10 text-white rounded font-bold transition-all duration-200 cursor-pointer text-left focus:outline-none border border-indigo-500/20";

					// Show correct view panel
					viewPanels.forEach(panel => {
						if (panel.id === targetTab) {
							panel.el?.classList.remove("hidden");
							// Run smooth entrance animation
							animate(panel.el, { opacity: [0, 1], y: [10, 0] }, { duration: 0.35, easing: "ease-out" });
						} else {
							panel.el?.classList.add("hidden");
						}
					});

					// Trigger logs rendering if logs view is opened
					if (targetTab === "logs") {
						renderFullLogs();
					}
				});
			});

			// ==========================================
			// Kubernetes Panel Simulator Logic
			// ==========================================
			const podsList = document.getElementById("sim-k8s-pods-list");
			const scalePodsBtn = document.getElementById("btn-sim-scale-pods");
			const podInfoCard = document.getElementById("sim-pod-info-card");
			const podDetailName = document.getElementById("pod-detail-name");
			const podDetailIp = document.getElementById("pod-detail-ip");
			const podDetailImage = document.getElementById("pod-detail-image");
			const closePodInfoBtn = document.getElementById("btn-close-pod-info");

			// Attach default pod detail events
			document.querySelectorAll(".btn-pod-details").forEach(btn => {
				btn.addEventListener("click", () => {
					const name = btn.getAttribute("data-pod");
					if (name) showPodInfo(name);
				});
			});

			function showPodInfo(name: string) {
				if (!podInfoCard || !podDetailName || !podDetailIp || !podDetailImage) return;
				podDetailName.textContent = `quickpulse-${name.toLowerCase().replace(/\s+/g, '-')}-7d9a8`;
				
				// Mock data depending on pod
				if (name.includes("Auth")) {
					podDetailIp.textContent = "10.244.1.43";
					podDetailImage.textContent = "quickpulse/auth:v1.12.0";
				} else if (name.includes("Engine")) {
					podDetailIp.textContent = "10.244.2.99";
					podDetailImage.textContent = "quickpulse/engine:v1.12.0";
				} else {
					podDetailIp.textContent = "10.244.1.84";
					podDetailImage.textContent = "quickpulse/worker:v1.12.0";
				}

				podInfoCard.classList.remove("hidden");
				animate(podInfoCard, { opacity: [0, 1], scale: [0.95, 1] }, { duration: 0.2 });
			}

			closePodInfoBtn?.addEventListener("click", () => {
				if (podInfoCard) {
					animate(podInfoCard, { opacity: 0, scale: 0.95 }, { duration: 0.15 }).then(() => {
						podInfoCard.classList.add("hidden");
					});
				}
			});

			scalePodsBtn?.addEventListener("click", () => {
				if (!podsList) return;
				const hex = Math.random().toString(16).substring(2, 6);
				const podName = `quickpulse-worker-scaled-${hex}`;
				
				const item = document.createElement("div");
				item.className = "flex items-center justify-between p-3 bg-white/[0.02] border border-white/[0.04] rounded-lg font-mono text-[10px] opacity-0";
				item.innerHTML = `
					<div class="flex items-center gap-3">
						<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
						<span class="text-white font-bold">${podName}</span>
					</div>
					<div class="flex items-center gap-4 text-slate-400">
						<span>Restarts: 0</span>
						<span>Just now</span>
						<button class="text-indigo-400 hover:underline text-[9px] btn-pod-details" data-pod="Worker Scaled ${hex}">Info</button>
					</div>
				`;
				podsList.appendChild(item);
				animate(item, { opacity: [0, 1], x: [-10, 0] }, { duration: 0.3 });

				// Attach click handler for info on new element
				item.querySelector(".btn-pod-details")?.addEventListener("click", () => {
					showPodInfo(`Worker Scaled ${hex}`);
				});

				addLog(`Kubernetes replica set scaled. Spawned pod ${podName}.`, "info");
			});

			// ==========================================
			// Logs Filter System Logic
			// ==========================================
			const fullLogsContainer = document.getElementById("sim-full-logs-container");
			const searchInput = document.getElementById("sim-log-search");
			const filterLevelButtons = document.querySelectorAll("#log-filters button");
			
			let currentLogLevelFilter = "all";
			let currentLogSearchQuery = "";

			filterLevelButtons.forEach(btn => {
				btn.addEventListener("click", () => {
					const level = btn.getAttribute("data-level");
					if (!level) return;

					// Reset styling
					filterLevelButtons.forEach(b => {
						b.className = "px-1.5 py-0.5 rounded bg-white/5 text-slate-400 hover:text-white cursor-pointer";
					});

					// Set active style
					btn.className = "px-1.5 py-0.5 rounded bg-indigo-500 text-white font-bold cursor-pointer";
					currentLogLevelFilter = level;
					renderFullLogs();
				});
			});

			searchInput?.addEventListener("input", (e) => {
				currentLogSearchQuery = (e.target as any).value.toLowerCase();
				renderFullLogs();
			});

			function renderFullLogs() {
				if (!fullLogsContainer) return;
				fullLogsContainer.innerHTML = "";

				const filtered = baseLogs.filter(log => {
					// Level Filter
					if (currentLogLevelFilter !== "all" && log.level !== currentLogLevelFilter) return false;
					// Search Query Filter
					if (currentLogSearchQuery && !log.text.toLowerCase().includes(currentLogSearchQuery)) return false;
					return true;
				});

				if (filtered.length === 0) {
					fullLogsContainer.innerHTML = `<div class="text-slate-500 text-center py-8">No matching logs found in simulation pool.</div>`;
					return;
				}

				filtered.forEach(log => {
					const div = document.createElement("div");
					div.className = "text-[10px] leading-relaxed border-b border-white/[0.01] pb-0.5";
					
					let levelBadge = "";
					if (log.level === "info") {
						levelBadge = `<span class="text-emerald-400 font-bold">[INFO]</span>`;
					} else if (log.level === "warn") {
						levelBadge = `<span class="text-amber-400 font-bold">[WARN]</span>`;
					} else if (log.level === "error") {
						levelBadge = `<span class="text-red-500 font-bold">[ERROR]</span>`;
					}

					div.innerHTML = `<span class="text-slate-500">${log.timestamp}</span> ${levelBadge} <span class="text-slate-300">${log.text}</span>`;
					fullLogsContainer.appendChild(div);
				});

				fullLogsContainer.scrollTop = fullLogsContainer.scrollHeight;
			}
		});
	</script>
</Layout>
