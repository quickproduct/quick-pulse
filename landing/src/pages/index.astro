---
import Layout from '../layouts/Layout.astro';
---

<Layout title="QuickPulse - Lightweight VPS & Docker Control Panel">
	<!-- Navigation -->
	<header class="w-full border-b border-white/[0.06] bg-[#0f1117]/80 backdrop-blur-md sticky top-0 z-50">
		<div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
			<div class="flex items-center gap-3">
				<svg class="w-6 h-6 text-indigo-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
				</svg>
				<span class="text-lg font-bold text-white tracking-tight">QuickPulse</span>
			</div>
			<nav class="hidden md:flex items-center gap-8 text-sm">
				<a href="#features" class="text-slate-400 hover:text-white transition-colors">Features</a>
				<a href="#demo" class="text-slate-400 hover:text-white transition-colors">Interactive Demo</a>
				<a href="/docs" class="text-slate-400 hover:text-white transition-colors font-semibold">Docs & Guide</a>
			</nav>
			<!-- Social Links (Replacing Console Button) -->
			<div class="flex items-center gap-4">
				<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-all hover:scale-105" aria-label="GitHub">
					<svg class="w-5.5 h-5.5" fill="currentColor" viewBox="0 0 24 24">
						<path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.44 22 12.017 22 6.484 17.522 2 12 2z"/>
					</svg>
				</a>
				<a href="https://discord.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-all hover:scale-105" aria-label="Discord">
					<svg class="w-5.5 h-5.5" fill="currentColor" viewBox="0 0 24 24">
						<path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.094 13.094 0 01-1.873-.894.077.077 0 01-.008-.128c.126-.093.252-.19.372-.287a.075.075 0 01.077-.011c3.92 1.793 8.18 1.793 12.061 0a.073.073 0 01.078.009c.12.099.246.195.373.289a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.894.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.156 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.156 2.418z"/>
					</svg>
				</a>
			</div>
		</div>
	</header>

	<!-- Hero Section -->
	<section class="relative pt-24 pb-16 px-6 overflow-hidden">
		<!-- Dynamic background mesh -->
		<div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none"></div>
		
		<!-- Glow effects -->
		<div class="absolute top-10 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-[100px] pointer-events-none"></div>

		<div class="max-w-5xl mx-auto text-center relative z-10 space-y-6 hero-content opacity-0">
			<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-indigo-500/10 text-indigo-300 border border-indigo-500/20">
				🚀 Self-Hosted Control Panel Built for Performance
			</span>
			<h1 class="text-4xl sm:text-7xl font-black text-white tracking-tight leading-none">
				Lightweight Infrastructure <br />
				<span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">Control Panel</span>
			</h1>
			<p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
				Administer and monitor Docker containers, Compose stacks, and Kubernetes resources in real-time. Runs on less than <span class="text-white font-bold">50MB of RAM</span>.
			</p>
			<div class="flex flex-col sm:flex-row justify-center gap-4 pt-4">
			</div>
		</div>
	</section>

	<!-- Interactive Sandbox Console Simulator (New Feature: Live understanding of the product) -->
	<section id="demo" class="max-w-6xl mx-auto px-6 pb-20 relative z-10">
		<div class="text-center max-w-2xl mx-auto mb-10 space-y-3">
			<h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">Interactive Live Sandbox</h2>
			<p class="text-sm text-slate-400">Interact with this simulated control panel widget to see how QuickPulse manages VPS loads and container restarts in real-time.</p>
		</div>

		<!-- Main Sandbox Window -->
		<div class="qp-card p-0 border border-white/[0.08] bg-[#121422] rounded-xl overflow-hidden shadow-2xl">
			<!-- Window Header -->
			<div class="flex items-center justify-between px-4 py-3 bg-[#1a1d2e] border-b border-white/[0.06] select-none">
				<div class="flex items-center gap-2">
					<span class="w-3 h-3 rounded-full bg-red-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-green-500/80"></span>
					<span class="text-xs text-slate-400 font-mono ml-2">sandbox-console-ui v1.0.0</span>
				</div>
				<div class="flex items-center gap-2 text-[10px] text-indigo-400 font-mono bg-indigo-500/10 px-2.5 py-0.5 rounded border border-indigo-500/20">
					● SIMULATOR MODE
				</div>
			</div>

			<!-- Dashboard Contents -->
			<div class="grid grid-cols-1 lg:grid-cols-4 min-h-[420px]">
				<!-- Sidebar simulator -->
				<div class="bg-[#0f1117] p-4 border-r border-white/[0.04] space-y-4 hidden lg:block font-mono text-xs text-slate-400">
					<div class="space-y-1" id="sandbox-tabs">
						<button data-tab="dashboard" class="w-full flex items-center gap-2 p-2 bg-indigo-500/10 text-white rounded font-bold transition-all duration-200 cursor-pointer text-left focus:outline-none border border-transparent">
							<span>📊</span> Dashboard
						</button>
						<button data-tab="containers" class="w-full flex items-center gap-2 p-2 text-slate-400 hover:bg-white/[0.02] hover:text-white rounded transition-all duration-200 cursor-pointer text-left focus:outline-none border border-transparent">
							<span>🐳</span> Containers
						</button>
						<button data-tab="kubernetes" class="w-full flex items-center gap-2 p-2 text-slate-400 hover:bg-white/[0.02] hover:text-white rounded transition-all duration-200 cursor-pointer text-left focus:outline-none border border-transparent">
							<span>☸</span> Kubernetes
						</button>
						<button data-tab="logs" class="w-full flex items-center gap-2 p-2 text-slate-400 hover:bg-white/[0.02] hover:text-white rounded transition-all duration-200 cursor-pointer text-left focus:outline-none border border-transparent">
							<span>📄</span> Logs
						</button>
					</div>
					<hr class="border-white/[0.05]" />
					<div class="text-[10px] text-slate-500 uppercase tracking-widest pl-2">System</div>
					<div class="text-[10px] pl-2 font-mono">
						Context: <span class="text-emerald-400">VPS-Local</span>
					</div>
				</div>

				<!-- Main Dashboard View Simulator -->
				<div class="lg:col-span-3 p-6 flex flex-col justify-between min-h-[420px]" id="sandbox-views-container">
					<!-- Panel 1: Dashboard View -->
					<div id="sim-view-dashboard" class="space-y-6 flex flex-col justify-between h-full transition-all duration-300">
						<!-- Top row: Dynamic SVG rings -->
						<div class="grid grid-cols-3 gap-4">
							<!-- CPU -->
							<div class="qp-card p-4 bg-white/[0.02] border border-white/[0.04] flex flex-col items-center justify-center text-center">
								<span class="text-[10px] uppercase font-bold text-slate-400 mb-2">CPU LOAD</span>
								<div class="relative w-18 h-18 flex items-center justify-center">
									<svg class="w-full h-full transform -rotate-90">
										<circle cx="36" cy="36" r="28" stroke="rgba(255,255,255,0.03)" stroke-width="4" fill="none" />
										<circle cx="36" cy="36" r="28" stroke="#818cf8" stroke-width="5" fill="none"
											stroke-dasharray="176" stroke-dashoffset="158" stroke-linecap="round"
											class="transition-all duration-500 ease-out" id="sim-cpu-circle" />
									</svg>
									<span class="absolute inset-0 flex items-center justify-center font-mono text-sm text-white font-bold" id="sim-cpu-txt">10%</span>
								</div>
							</div>
							<!-- Memory -->
							<div class="qp-card p-4 bg-white/[0.02] border border-white/[0.04] flex flex-col items-center justify-center text-center">
								<span class="text-[10px] uppercase font-bold text-slate-400 mb-2">MEMORY</span>
								<div class="relative w-18 h-18 flex items-center justify-center">
									<svg class="w-full h-full transform -rotate-90">
										<circle cx="36" cy="36" r="28" stroke="rgba(255,255,255,0.03)" stroke-width="4" fill="none" />
										<circle cx="36" cy="36" r="28" stroke="#22d3ee" stroke-width="5" fill="none"
											stroke-dasharray="176" stroke-dashoffset="110" stroke-linecap="round"
											class="transition-all duration-500 ease-out" id="sim-mem-circle" />
									</svg>
									<span class="absolute inset-0 flex items-center justify-center font-mono text-sm text-white font-bold" id="sim-mem-txt">37%</span>
								</div>
							</div>
							<!-- Net in -->
							<div class="qp-card p-4 bg-white/[0.02] border border-white/[0.04] flex flex-col items-center justify-center text-center">
								<span class="text-[10px] uppercase font-bold text-slate-400 mb-2">CONTAINERS</span>
								<div class="relative w-18 h-18 flex items-center justify-center">
									<svg class="w-full h-full transform -rotate-90">
										<circle cx="36" cy="36" r="28" stroke="rgba(255,255,255,0.03)" stroke-width="4" fill="none" />
										<circle cx="36" cy="36" r="28" stroke="#34d399" stroke-width="5" fill="none"
											stroke-dasharray="176" stroke-dashoffset="44" stroke-linecap="round"
											class="transition-all duration-500 ease-out" id="sim-net-circle" />
									</svg>
									<span class="absolute inset-0 flex items-center justify-center font-mono text-sm text-white font-bold" id="sim-net-txt">3/4</span>
								</div>
							</div>
						</div>

						<!-- Container status & simulation triggers -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<!-- Container List Widget -->
							<div class="qp-card bg-white/[0.01] border-white/[0.04] p-4 text-xs font-mono space-y-2">
								<div class="text-[10px] font-bold uppercase tracking-wider text-slate-500 pb-2">Active Containers</div>
								<div class="flex items-center justify-between border-b border-white/[0.04] pb-1.5">
									<span class="text-white">quickpulse-backend</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Running</span>
								</div>
								<div class="flex items-center justify-between border-b border-white/[0.04] pb-1.5">
									<span class="text-white" id="container-db-name">sqlite-database</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" id="container-db-status">Running</span>
								</div>
								<div class="flex items-center justify-between">
									<span class="text-white" id="container-worker-name">batch-worker</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" id="container-worker-status">Running</span>
								</div>
							</div>

							<!-- Action Panel buttons -->
							<div class="qp-card bg-white/[0.01] border-white/[0.04] p-4 flex flex-col justify-between gap-3">
								<div class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Interactive Simulation Actions</div>
								<div class="grid grid-cols-2 gap-2 text-[10px]">
									<button class="qp-btn qp-btn-ghost px-2 py-2 text-[10px] hover:border-red-500/50 hover:text-red-400" id="btn-spike">
										💥 Spike CPU Load
									</button>
									<button class="qp-btn qp-btn-ghost px-2 py-2 text-[10px] hover:border-indigo-500/50 hover:text-indigo-400" id="btn-restart">
										🔄 Restart Database
									</button>
									<button class="qp-btn qp-btn-ghost col-span-2 px-2 py-2 text-[10px] hover:border-amber-500/50 hover:text-amber-400" id="btn-toggle-worker">
										🛑 Toggle Batch Worker
									</button>
								</div>
							</div>
						</div>

						<!-- Bottom Row: Terminal logs simulator -->
						<div class="relative bg-black/60 rounded border border-white/[0.05] p-3 font-mono text-[10px] overflow-hidden">
							<div class="text-[9px] text-slate-500 uppercase tracking-widest border-b border-white/[0.05] pb-1.5 mb-2 flex items-center justify-between">
								<span>Log Terminal stream</span>
								<span class="text-indigo-400 flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-ping"></span> Live</span>
							</div>
							<div class="h-20 overflow-y-auto space-y-1.5 text-slate-400" id="sim-logs-container">
								<div class="text-slate-500">[SYSTEM] Initialization completed. Running SQLite WAL...</div>
								<div class="text-slate-500">[SYSTEM] Background telemetry goroutine started successfully.</div>
								<div class="text-emerald-400">[INFO] WebSocket connected successfully to /ws/metrics.</div>
							</div>
						</div>
					</div>

					<!-- Panel 2: Containers View -->
					<div id="sim-view-containers" class="hidden flex flex-col space-y-4 h-full transition-all duration-300">
						<div class="flex items-center justify-between">
							<span class="text-sm font-bold text-white font-mono">🐳 Container Lifecycle Manager</span>
							<span class="text-[10px] font-mono text-slate-400" id="sim-containers-count">Total: 3 Active</span>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<!-- Backend Container Card -->
							<div class="qp-card p-4 bg-white/[0.01] border-white/[0.05] flex flex-col justify-between gap-3 font-mono text-xs">
								<div class="flex items-center justify-between">
									<span class="text-white font-bold">quickpulse-backend</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Running</span>
								</div>
								<div class="space-y-1 text-[10px] text-slate-400">
									<div>CPU: <span class="text-white" id="sim-card-backend-cpu">0.45%</span></div>
									<div class="w-full bg-white/[0.05] h-1 rounded overflow-hidden">
										<div class="bg-indigo-400 h-full w-[12%] transition-all duration-300" id="sim-card-backend-bar"></div>
									</div>
									<div class="pt-1">RAM: <span class="text-white">12.1 MB / 64 MB</span></div>
								</div>
								<div class="flex gap-2 text-[10px] pt-1">
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 text-slate-500 border-white/5 cursor-not-allowed" disabled>Stop</button>
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 hover:border-indigo-500/45 text-slate-300" id="btn-card-restart-backend">Restart</button>
								</div>
							</div>

							<!-- DB Container Card -->
							<div class="qp-card p-4 bg-white/[0.01] border-white/[0.05] flex flex-col justify-between gap-3 font-mono text-xs">
								<div class="flex items-center justify-between">
									<span class="text-white font-bold">sqlite-database</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" id="sim-card-db-status">Running</span>
								</div>
								<div class="space-y-1 text-[10px] text-slate-400">
									<div>CPU: <span class="text-white" id="sim-card-db-cpu">0.12%</span></div>
									<div class="w-full bg-white/[0.05] h-1 rounded overflow-hidden">
										<div class="bg-cyan-400 h-full w-[4%] transition-all duration-300" id="sim-card-db-bar"></div>
									</div>
									<div class="pt-1">RAM: <span class="text-white">2.4 MB / 32 MB</span></div>
								</div>
								<div class="flex gap-2 text-[10px] pt-1">
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 text-slate-500 border-white/5 cursor-not-allowed" disabled>Stop</button>
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 hover:border-indigo-500/45 text-slate-300" id="btn-card-restart-db">Restart</button>
								</div>
							</div>

							<!-- Batch Worker Container Card -->
							<div class="qp-card p-4 bg-white/[0.01] border-white/[0.05] flex flex-col justify-between gap-3 font-mono text-xs">
								<div class="flex items-center justify-between">
									<span class="text-white font-bold">batch-worker</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" id="sim-card-worker-status">Running</span>
								</div>
								<div class="space-y-1 text-[10px] text-slate-400">
									<div>CPU: <span class="text-white" id="sim-card-worker-cpu">0.82%</span></div>
									<div class="w-full bg-white/[0.05] h-1 rounded overflow-hidden">
										<div class="bg-emerald-400 h-full w-[18%] transition-all duration-300" id="sim-card-worker-bar"></div>
									</div>
									<div class="pt-1">RAM: <span class="text-white">4.8 MB / 64 MB</span></div>
								</div>
								<div class="flex gap-2 text-[10px] pt-1">
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 text-red-400 hover:bg-red-500/10 hover:border-red-500/20" id="btn-card-toggle-worker">Stop</button>
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 hover:border-indigo-500/45 text-slate-300" id="btn-card-restart-worker">Restart</button>
								</div>
							</div>

							<!-- Redis Container Card -->
							<div class="qp-card p-4 bg-white/[0.01] border-white/[0.05] flex flex-col justify-between gap-3 font-mono text-xs">
								<div class="flex items-center justify-between">
									<span class="text-white font-bold">redis-cache</span>
									<span class="px-2 py-0.5 rounded text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Running</span>
								</div>
								<div class="space-y-1 text-[10px] text-slate-400">
									<div>CPU: <span class="text-white">0.05%</span></div>
									<div class="w-full bg-white/[0.05] h-1 rounded overflow-hidden">
										<div class="bg-amber-400 h-full w-[2%]"></div>
									</div>
									<div class="pt-1">RAM: <span class="text-white">1.8 MB / 16 MB</span></div>
								</div>
								<div class="flex gap-2 text-[10px] pt-1">
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 text-slate-500 border-white/5 cursor-not-allowed" disabled>Stop</button>
									<button class="qp-btn qp-btn-ghost px-2 py-1 flex-1 hover:border-indigo-500/45 text-slate-300" id="btn-card-restart-redis">Restart</button>
								</div>
							</div>
						</div>
					</div>

					<!-- Panel 3: Kubernetes View -->
					<div id="sim-view-kubernetes" class="hidden flex flex-col space-y-4 h-full transition-all duration-300">
						<div class="flex items-center justify-between">
							<span class="text-sm font-bold text-white font-mono">☸ Kubernetes Pod Cluster Monitor</span>
							<button class="qp-btn qp-btn-ghost px-3 py-1.5 text-[10px] hover:border-indigo-500/45 text-indigo-400" id="btn-sim-scale-pods">
								➕ Scale Deployment
							</button>
						</div>
						
						<!-- Simulated pods list -->
						<div class="space-y-2 max-h-[160px] overflow-y-auto pr-1" id="sim-k8s-pods-list">
							<div class="flex items-center justify-between p-3 bg-white/[0.02] border border-white/[0.04] rounded-lg font-mono text-[10px]" id="pod-auth">
								<div class="flex items-center gap-3">
									<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
									<span class="text-white font-bold">quickpulse-auth-7d9a8-abcde</span>
								</div>
