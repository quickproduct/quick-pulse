---
import Layout from '../layouts/Layout.astro';

const sections = [
	{ id: 'overview', title: 'Product Overview' },
	{ id: 'architecture', title: 'System Architecture' },
	{ id: 'setup', title: 'Developer & Setup' },
	{ id: 'deployment', title: 'Deployment & Infra' },
	{ id: 'api', title: 'API & WebSockets' },
	{ id: 'mcp', title: 'AI Integration (MCP)' }
];
---

<Layout title="Documentation - QuickPulse Control Panel">
	<!-- Navigation -->
	<header class="w-full border-b border-white/[0.06] bg-[#0f1117]/80 backdrop-blur-md sticky top-0 z-50">
		<div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
			<div class="flex items-center gap-3">
				<a href="/" class="flex items-center gap-3">
					<svg class="w-6 h-6 text-indigo-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
						<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
					</svg>
					<span class="text-lg font-bold text-white tracking-tight">QuickPulse Docs</span>
				</a>
			</div>
			<nav class="hidden md:flex items-center gap-8 text-sm">
				<a href="/" class="text-slate-400 hover:text-white transition-colors">Landing Page</a>
			</nav>
			<div>
			</div>
		</div>
	</header>

	<div class="max-w-7xl mx-auto px-6 py-10 flex flex-col md:flex-row gap-8">
		<!-- Left Sidebar Topics -->
		<aside class="w-full md:w-64 shrink-0">
			<div class="sticky top-24 space-y-2">
				<h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 mb-4">Documentation Topics</h3>
				<nav class="space-y-1" id="docs-nav">
					{sections.map((sec, idx) => (
						<button
							data-sec-id={sec.id}
							class={`w-full text-left px-4 py-2.5 rounded-lg text-sm transition-all font-semibold flex items-center justify-between doc-tab-btn
								${idx === 0 
									? 'bg-indigo-500/10 text-white border-l-2 border-indigo-500' 
									: 'text-slate-400 hover:bg-white/[0.02] hover:text-white'}`}
						>
							<span>{sec.title}</span>
							<svg class={`w-3.5 h-3.5 text-indigo-400 ${idx === 0 ? 'block' : 'hidden'} arrow-icon`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
							</svg>
						</button>
					))}
				</nav>
			</div>
		</aside>

		<!-- Main Panel Content -->
		<main class="flex-1 min-w-0 bg-white/[0.01] border border-white/[0.04] p-8 rounded-xl space-y-8" id="docs-content">
			<!-- Section 1: Overview -->
			<article id="sec-overview" class="space-y-4 doc-section block">
				<h1 class="text-3xl font-extrabold text-white">Product Overview</h1>
				<p class="text-slate-400 leading-relaxed text-sm">
					QuickPulse is an ultra-lightweight, self-hosted control panel optimized to monitor and manage Docker containers, VPS settings, and Kubernetes infrastructure in real-time.
				</p>
				<p class="text-slate-400 leading-relaxed text-sm">
					Because it functions primarily as a system monitoring framework, QuickPulse has been explicitly re-architected to consume <strong>near-zero resource overhead</strong>. It safely operates on micro or low-end VPS resources without depriving your production apps of CPU and RAM.
				</p>

				<h3 class="text-lg font-bold text-white pt-4">Key Capabilities</h3>
				<ul class="space-y-2.5 text-sm text-slate-400 list-disc list-inside pl-2">
					<li><strong class="text-white">Real-Time Metrics:</strong> Sub-second updates on memory, load averages, processes, disk throughput, and network interface rates.</li>
					<li><strong class="text-white">Docker Management:</strong> Direct API hooks to pull, start, stop, pause, restart, and inspect containers.</li>
					<li><strong class="text-white">Compose Stack Support:</strong> Start and scale multi-container Docker Compose stacks with complete status mappings.</li>
					<li><strong class="text-white">Kubernetes Integration:</strong> Support for kubeconfig configs to discover cluster nodes, namespaces, deployments, services, pods, and events.</li>
					<li><strong class="text-white">AI Assistant (MCP):</strong> Integrated Model Context Protocol allowing LLMs (such as Cursor or Claude) to manage your server safely via structured tools.</li>
				</ul>
			</article>

			<!-- Section 2: Architecture -->
			<article id="sec-architecture" class="space-y-6 doc-section hidden">
				<h1 class="text-3xl font-extrabold text-white">System Architecture</h1>
				<p class="text-slate-400 leading-relaxed text-sm">
					QuickPulse is compiled into a single static Go container image. This eliminates high-overhead services like PostgreSQL databases, Redis pub/sub hubs, and proxy containers.
				</p>

				<div class="qp-card p-5 border border-white/[0.04] bg-white/[0.01] space-y-3">
					<h3 class="text-sm font-bold text-white">Go-Consolidated Design Benefits</h3>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs">
						<div class="p-3 bg-white/5 rounded border border-white/5">
							<strong class="text-indigo-400 block mb-1">SQLite WAL Mode</strong>
							Runs database queries sequentially without file locks, using connections restricted to 1 write context to prevent deadlocks.
						</div>
						<div class="p-3 bg-white/5 rounded border border-white/5">
							<strong class="text-indigo-400 block mb-1">In-Memory Pub/Sub</strong>
							Replaced heavy Redis components with thread-safe maps and channels (`sync.RWMutex`) to route live signals.
						</div>
					</div>
				</div>

				<h3 class="text-lg font-bold text-white pt-4">Telemetry Collection Pipeline</h3>
				<p class="text-slate-400 text-sm leading-relaxed">
					Telemetry workers start at runtime as Go routines. CPU and RAM statistics are pulled via `gopsutil` every 10 seconds, validated against user thresholds, stored, and broadcast to open WebSockets.
				</p>
			</article>

			<!-- Section 3: Setup -->
			<article id="sec-setup" class="space-y-6 doc-section hidden">
				<h1 class="text-3xl font-extrabold text-white">Developer & Setup Guide</h1>
				<p class="text-slate-400 leading-relaxed text-sm">
					Follow these steps to run and develop QuickPulse locally.
				</p>

				<div class="space-y-4">
					<h3 class="text-base font-bold text-white">Local Run Commands</h3>
					
					<div class="relative bg-black/40 border border-white/10 rounded-lg overflow-hidden font-mono text-xs">
						<div class="flex items-center justify-between px-4 py-2 border-b border-white/5 bg-white/5 text-slate-400">
							<span>Shell Session</span>
							<button class="hover:text-white transition-colors text-[10px] copy-btn" data-clipboard-text="git clone https://github.com/your-org/quickpulse.git&#10;cd quickpulse&#10;cp .env.example .env&#10;docker compose up -d">
								Copy
							</button>
						</div>
						<pre class="p-4 text-emerald-400 overflow-x-auto"><code>git clone https://github.com/your-org/quickpulse.git
cd quickpulse
cp .env.example .env
docker compose up -d</code></pre>
					</div>

					<h3 class="text-base font-bold text-white pt-4">Makefile Helpers</h3>
					<div class="space-y-2 text-sm text-slate-400">
						<div class="flex justify-between border-b border-white/5 pb-2">
							<code class="text-indigo-300">make up</code>
							<span>Compiles local changes and restarts container services.</span>
						</div>
						<div class="flex justify-between border-b border-white/5 pb-2">
							<code class="text-indigo-300">make down</code>
							<span>Stops container services and releases network ports.</span>
						</div>
						<div class="flex justify-between border-b border-white/5 pb-2">
							<code class="text-indigo-300">make test</code>
							<span>Triggers unit tests on handlers, database queries, and workers.</span>
						</div>
					</div>
				</div>
			</article>

			<!-- Section 4: Deployment -->
			<article id="sec-deployment" class="space-y-6 doc-section hidden">
				<h1 class="text-3xl font-extrabold text-white">Deployment & Production</h1>
				<p class="text-slate-400 leading-relaxed text-sm">
					Production uses a multi-stage Docker build to build the static Svelte bundle, compile the Go binary without debugging symbols, and package them into a minimal Alpine container.
				</p>

				<h3 class="text-base font-bold text-white pt-2">Recommended Docker Compose Config</h3>
				
				<div class="relative bg-black/40 border border-white/10 rounded-lg overflow-hidden font-mono text-xs">
					<div class="flex items-center justify-between px-4 py-2 border-b border-white/5 bg-white/5 text-slate-400">
						<span>docker-compose.yml</span>
						<button class="hover:text-white transition-colors text-[10px] copy-btn" data-clipboard-text="version: '3.8'&#10;services:&#10;  qp-app:&#10;    image: quickpulse/app:latest&#10;    container_name: quickpulse-app&#10;    ports:&#10;      - &quot;80:8000&quot;&#10;    volumes:&#10;      - /var/run/docker.sock:/var/run/docker.sock:ro&#10;      - qp-data:/app/data&#10;    deploy:&#10;      resources:&#10;        limits:&#10;          cpus: '0.25'&#10;          memory: 64M">
							Copy
						</button>
					</div>
					<pre class="p-4 text-cyan-400 overflow-x-auto"><code>version: '3.8'
services:
  qp-app:
    image: quickpulse/app:latest
    container_name: quickpulse-app
    ports:
      - "80:8000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - qp-data:/app/data
    deploy:
      resources:
        limits:
          cpus: '0.25'
          memory: 64M</code></pre>
				</div>
			</article>

			<!-- Section 5: API -->
			<article id="sec-api" class="space-y-6 doc-section hidden">
				<h1 class="text-3xl font-extrabold text-white">API & WebSockets Reference</h1>
				<p class="text-slate-400 leading-relaxed text-sm">
					Use these endpoints to integrate third-party alerting scripts or scripts with QuickPulse backend capabilities.
				</p>

				<div class="space-y-4">
					<h3 class="text-base font-bold text-white">Core REST Endpoints</h3>
					<div class="space-y-3 text-xs font-mono">
						<div class="p-2.5 bg-white/5 rounded border border-white/5 flex justify-between items-center">
							<span><span class="text-emerald-400 font-bold mr-2">POST</span>/api/v1/auth/login</span>
							<span class="text-slate-400">Get access token</span>
						</div>
						<div class="p-2.5 bg-white/5 rounded border border-white/5 flex justify-between items-center">
							<span><span class="text-blue-400 font-bold mr-2">GET</span>/api/v1/containers</span>
							<span class="text-slate-400">List Docker containers</span>
						</div>
						<div class="p-2.5 bg-white/5 rounded border border-white/5 flex justify-between items-center">
							<span><span class="text-blue-400 font-bold mr-2">GET</span>/api/v1/kubernetes/pods</span>
							<span class="text-slate-400">List cluster pods</span>
						</div>
						<div class="p-2.5 bg-white/5 rounded border border-white/5 flex justify-between items-center">
							<span><span class="text-blue-400 font-bold mr-2">GET</span>/api/v1/dashboard</span>
							<span class="text-slate-400">Get combined system summary</span>
						</div>
					</div>

					<h3 class="text-base font-bold text-white pt-4">Active WebSockets</h3>
					<div class="space-y-2 text-xs font-mono text-slate-400">
						<div class="flex justify-between border-b border-white/5 pb-2">
							<code class="text-indigo-300">/ws/metrics</code>
							<span>Pipes live RAM, CPU, load telemetry to client.</span>
						</div>
						<div class="flex justify-between border-b border-white/5 pb-2">
							<code class="text-indigo-300">/ws/logs/stream</code>
							<span>Central log publisher with pause support.</span>
						</div>
					</div>
				</div>
			</article>

			<!-- Section 6: MCP -->
			<article id="sec-mcp" class="space-y-6 doc-section hidden">
				<h1 class="text-3xl font-extrabold text-white">AI Agent Integration (MCP)</h1>
				<p class="text-slate-400 leading-relaxed text-sm">
					QuickPulse runs an integrated Model Context Protocol (MCP) server written in Python under `mcp/`. This allows agentic IDE extensions (such as Claude or Cursor) to execute administration controls and read events.
				</p>

				<h3 class="text-base font-bold text-white pt-2">Sample MCP configuration (.json)</h3>
				
				<div class="relative bg-black/40 border border-white/10 rounded-lg overflow-hidden font-mono text-xs">
					<div class="flex items-center justify-between px-4 py-2 border-b border-white/5 bg-white/5 text-slate-400">
						<span>claude_desktop_config.json</span>
						<button class="hover:text-white transition-colors text-[10px] copy-btn" data-clipboard-text="{&#10;  &quot;mcpServers&quot;: {&#10;    &quot;quickpulse&quot;: {&#10;      &quot;command&quot;: &quot;python&quot;,&#10;      &quot;args&quot;: [&quot;-m&quot;, &quot;mcp.server&quot;],&#10;      &quot;env&quot;: {&#10;        &quot;QP_API_URL&quot;: &quot;http://localhost:8000&quot;,&#10;        &quot;QP_ADMIN_EMAIL&quot;: &quot;admin@quickpulse.local&quot;,&#10;        &quot;QP_ADMIN_PASSWORD&quot;: &quot;your_secure_password&quot;&#10;      }&#10;    }&#10;  }&#10;}">
							Copy
						</button>
					</div>
					<pre class="p-4 text-emerald-400 overflow-x-auto"><code>&#123;
  "mcpServers": &#123;
    "quickpulse": &#123;
      "command": "python",
      "args": ["-m", "mcp.server"],
      "env": &#123;
        "QP_API_URL": "http://localhost:8000",
        "QP_ADMIN_EMAIL": "admin@quickpulse.local",
        "QP_ADMIN_PASSWORD": "your_secure_password"
      &#125;
    &#125;
  &#125;
&#125;</code></pre>
				</div>
			</article>
		</main>
	</div>

	<!-- Interactive Client Script -->
	<script>
		document.addEventListener("astro:page-load", () => {
			const tabButtons = document.querySelectorAll(".doc-tab-btn");
			const docSections = document.querySelectorAll(".doc-section");

			// Tab Navigation switching
			tabButtons.forEach(btn => {
				btn.addEventListener("click", () => {
					const targetId = btn.getAttribute("data-sec-id");

					// Toggle active classes on buttons
					tabButtons.forEach(b => {
						b.classList.remove("bg-indigo-500/10", "text-white", "border-l-2", "border-indigo-500");
						b.classList.add("text-slate-400", "hover:bg-white/[0.02]", "hover:text-white");
						const arrow = b.querySelector(".arrow-icon");
						if (arrow) {
							arrow.classList.remove("block");
							arrow.classList.add("hidden");
						}
					});

					btn.classList.add("bg-indigo-500/10", "text-white", "border-l-2", "border-indigo-500");
					btn.classList.remove("text-slate-400", "hover:bg-white/[0.02]", "hover:text-white");
					const activeArrow = btn.querySelector(".arrow-icon");
					if (activeArrow) {
						activeArrow.classList.remove("hidden");
						activeArrow.classList.add("block");
					}

					// Toggle visible sections
					docSections.forEach(section => {
						if (section.id === `sec-${targetId}`) {
							section.classList.remove("hidden");
							section.classList.add("block");
						} else {
							section.classList.remove("block");
							section.classList.add("hidden");
						}
					});
				});
			});

			// Clipboard copy logic
			const copyButtons = document.querySelectorAll(".copy-btn");
			copyButtons.forEach(btn => {
				btn.addEventListener("click", () => {
					const text = btn.getAttribute("data-clipboard-text");
					if (!text) return;

					navigator.clipboard.writeText(text).then(() => {
						const originalText = btn.textContent;
						btn.textContent = "Copied!";
						btn.style.color = "#34d399";
						setTimeout(() => {
							btn.textContent = originalText;
							btn.style.color = "";
						}, 2000);
					});
				});
			});
		});
	</script>
</Layout>
